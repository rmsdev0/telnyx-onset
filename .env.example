# Telnyx auth: one key authenticates Call Control, the STT and TTS WebSockets,
# and LLM inference. The public key verifies inbound webhook signatures.
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=

# Telephony identity. The connection_id is the Voice API Application id; set it
# to ignore calls for other applications on the same key.
TELNYX_PHONE_NUMBER=
TELNYX_CONNECTION_ID=

# Public wss:// address Telnyx dials for the bidirectional media stream. Must be
# this server's /ws/media route, reachable from Telnyx (for example an ngrok or
# cloudflared tunnel during development).
MEDIA_STREAM_URL=wss://your-tunnel.example/ws/media

# Audio: one rate end to end so nothing is resampled in app code. L16 is 16 kHz
# linear PCM16; the only transcode in the loop is decoding the TTS socket's MP3.
MEDIA_CODEC=L16
SAMPLE_RATE=16000

# Where the agent's audio is injected. "self" plays it to the caller on a single
# answered call; "opposite" is for bridged calls (and leaves a single caller in
# silence).
STREAM_BIDIRECTIONAL_TARGET_LEGS=self

# Half-duplex: the agent stops listening while it talks so it cannot interrupt
# itself through line/acoustic echo. Set false for full-duplex frame-level
# barge-in once the audio path is confirmed echo-free.
HALF_DUPLEX=true

# STT engine. Deepgram is a third-party model reached through Telnyx's single API
# (never relabel it "Telnyx STT"). Set STT_ENGINE=Telnyx for an all-first-party
# engine; the schema and wiring are identical.
STT_ENGINE=Deepgram
STT_LANGUAGE=en

# TTS voice. NaturalHD is a first-party Telnyx voice tier. AWS Polly, Azure, and
# ElevenLabs voices also drop in here via their voice ids.
TTS_VOICE=Telnyx.NaturalHD.astra

# LLM (Telnyx inference, OpenAI-compatible). Pinned deliberately; Telnyx is
# moving toward Kimi-K2.6.
LLM_MODEL=moonshotai/Kimi-K2.5

# Spend and volume protection (0 disables)
MAX_CONCURRENT_CALLS=10
MAX_TOKENS_PER_CALL=0

# Server
HOST=0.0.0.0
PORT=8000
ENV=development
LOG_LEVEL=info
